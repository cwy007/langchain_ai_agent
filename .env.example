RERANK_URL=https://dashscope.aliyuncs.com/api/v1/services/rerank/text-rerank/text-rerank
RERANK_MODEL_NAME=qwen3-vl-rerank


# 高德地图
AMAP_API_KEY=xxxxx

ALLOWED_PATHS=/Users/chanweiyan/workspace/noder/ai-agent/tool_test,/Users/chanweiyan/Desktop

# 腾讯云配置
TENCENT_SECRET_ID=xxxxx
TENCENT_SECRET_KEY=xxxxx
